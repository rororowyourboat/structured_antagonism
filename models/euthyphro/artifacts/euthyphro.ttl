    gds-ir:direction "covariant" ;
    gds-ir:isFeedback false ;
    gds-ir:isTemporal false ;
    gds-ir:label "Current Commitments" ;
    gds-ir:source "Euthyphro View" ;
    gds-ir:target "Euthyphro" ;
